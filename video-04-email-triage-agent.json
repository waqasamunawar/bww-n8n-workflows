        "messages": {
          "values": [
            {
              "content": "=Please classify this email.\n\nSubject: {{ $('Watch Gmail Inbox').item.json.subject }}\n\nFrom: {{ $('Watch Gmail Inbox').item.json.from.value[0].name }}\n\nBody:\n{{ $('Watch Gmail Inbox').item.json.text }}"
            }
          ]
        },
        "options": {
          "system": "=You are an email classification assistant for a service business. Your job is to \nread every incoming email and return a structured classification.\n\nCATEGORIES (pick exactly one):\n- sales_inquiry: Someone interested in hiring, buying, or working with the business\n- support_request: An existing client or customer needing help with something\n- complaint: Someone expressing dissatisfaction, frustration, or a problem\n- spam: Newsletters, promotions, automated notifications, cold outreach, receipts\n- internal: Team communication, personal emails, anything not from a client or prospect\n\nURGENCY SCORE (1–5):\n1 = No urgency — spam, newsletters, casual\n2 = Low — general enquiry, no time pressure\n3 = Medium — needs a reply within 24 hours\n4 = High — needs a reply today\n5 = Critical — needs immediate attention (angry client, missed deadline, emergency)\n\nRULES:\n- Complaints always score 4 or 5 on urgency — never lower\n- Sales inquiries with budget and timeline mentioned score 3 or above\n- Spam always scores 1\n- When in doubt between two categories, choose the higher-urgency one\n\nCRITICAL OUTPUT RULE:\nReturn ONLY the raw JSON below. No explanation. No markdown code fences. \nNo extra text before or after. Just the raw JSON.\n\n{\n  \"category\": \"[one of the 5 categories above]\",\n  \"urgency\": [number 1-5],\n  \"summary\": \"[one sentence describing what this email is about]\",\n  \"sender_name\": \"[first name of the sender if identifiable, otherwise Unknown]\"\n}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        -240,
        -152
      ],
      "id": "1a1f1836-d781-4fd1-8748-76407325e98b",
      "name": "Classify Email",
      "credentials": {
        "anthropicApi": {
          "id": "RhUuHFD4fBWpwwP6",
          "name": "Anthropic - PM Waqas"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Handle both output structures\nlet rawText = item.text || (item.content && item.content[0] && item.content[0].text);\n\n// Strip markdown code fences if present\nrawText = rawText.replace(/^```json\\s*/i, '').replace(/\\s*```$/, '').trim();\n\n// Parse into clean fields\nconst parsed = JSON.parse(rawText);\n\nreturn [{\n  json: {\n    category: parsed.category,\n    urgency: parsed.urgency,\n    summary: parsed.summary,\n    sender_name: parsed.sender_name\n  }\n}];"
      },
