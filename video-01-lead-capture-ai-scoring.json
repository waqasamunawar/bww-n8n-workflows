    {
      "parameters": {
        "jsCode": "// Get the text output from Claude\nconst item = $input.first().json;\n\n// Handle both possible output structures from n8n's Anthropic node\nlet rawText = item.text || (item.content && item.content[0] && item.content[0].text);\n\n// Strip markdown code fences if Claude added them (e.g. ```json ... ```)\nrawText = rawText.replace(/^```json\\s*/i, '').replace(/\\s*```$/, '').trim();\n\n// Parse the cleaned text into a real JSON object\nconst parsed = JSON.parse(rawText);\n\n// Return all the fields as flat, usable data\nreturn [{\n  json: {\n    score: parsed.score,\n    tier: parsed.tier,\n    reasoning: parsed.reasoning,\n    email_subject: parsed.email_subject,\n    email_body: parsed.email_body\n  }\n}];\n"
      },
