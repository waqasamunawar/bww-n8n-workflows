    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text;\n\n// Remove markdown code blocks if Claude added them\nconst cleaned = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\n// Parse the JSON\nconst q = JSON.parse(cleaned);\n\n// Get current question number from Node 2 and add 1\nconst currentNumber = $('Get row(s) in sheet').first().json.Value;\nconst newNumber = parseInt(currentNumber) + 1;\n\n// Format the date\nconst today = new Date();\nconst dateStr = today.toLocaleDateString('en-US', { \n  weekday: 'long', \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric' \n});\n\n// Build the LinkedIn post text\nconst postText = `PMP Question #${newNumber} | ${q.topic} - ${dateStr}\n\n${q.scenario}\n\nA. ${q.optionA}\nB. ${q.optionB}\nC. ${q.optionC}\nD. ${q.optionD}\n\n👇 Drop your answer in the comments! Is it A, B, C, or D?\n\n♻️ Repost to share with your network.\n➕ Follow Waqas Munawar for more insights on effective project management and delivery.\n🚀 I’m building practical AI tools and trainings for project managers -check the link in the comments to join the waitlist and get early access.`;\n\n// Build the comment text\nconst commentText = \"✅ The correct answer is \" + q.correctAnswer + \".\\n\\n\" + q.explanation + \"\\n\\n📌 Follow for Question #\" + (newNumber + 1) + \" coming soon!\";\n\nreturn {\n  questionNumber: newNumber,\n  postDate: dateStr,\n  topic: q.topic,\n  scenario: q.scenario,\n  optionA: q.optionA,\n  optionB: q.optionB,\n  optionC: q.optionC,\n  optionD: q.optionD,\n  correctAnswer: q.correctAnswer,\n  explanation: q.explanation,\n  postText: postText,\n  commentText: commentText\n};"
      },
